---
import Container from "../Container.astro";
import SectionHeading from "../SectionHeading.astro";
import { useT } from "../../../i18n/utils";
const t = useT(Astro.currentLocale).metrics;
const metrics = t.items;
---

<section id="metrics" class="py-24 sm:py-32">
  <Container>
    <SectionHeading eyebrow={t.eyebrow} title={t.title} lead={t.lead} />
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        metrics.map(([t, d]) => (
          <div class="rounded-2xl border border-border bg-surface p-6">
            <h3 class="text-sm font-semibold tracking-tight text-fg">{t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-fg-muted">{d}</p>
            <div class="mt-5 h-1.5 w-full overflow-hidden rounded-full bg-muted">
              <div class="h-full w-2/3 rounded-full bg-primary"></div>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
