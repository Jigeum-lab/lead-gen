---
import Layout from "../../layouts/Layout.astro";
import JsonLd from "../../components/seo/JsonLd.astro";
import Navbar from "../../components/site/sections/Navbar.astro";
import Footer from "../../components/site/sections/Footer.astro";
import CtaBand from "../../components/site/sections/CtaBand.astro";
import Container from "../../components/site/Container.astro";
import Badge from "../../components/site/Badge.astro";
import clients from "../../data/clients.json";

const site = Astro.site?.href.replace(/\/$/, "") ?? "https://lead-gen.team";
const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/en/` },
    { "@type": "ListItem", position: 2, name: "Clients & Partners", item: `${site}/en/partners/` },
  ],
};
---

<Layout
  title="Clients & Partners — trusted by 32+ brands | LeadGenLab"
  description="From enterprises and global corporations like SK, Hana, KB, Doosan, and GC to startups — the brands that began AI Visibility Optimization with LeadGenLab."
>
  <JsonLd slot="head" extra={[breadcrumb]} />
  <Navbar />
  <main id="main-content" tabindex="-1">
    <section class="relative overflow-hidden border-b border-border">
      <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-full bg-gradient-to-b from-primary-subtle/60 to-transparent"></div>
      <Container class="py-20 text-center sm:py-24">
        <Badge>Clients &amp; Partners</Badge>
        <h1 class="mt-5 text-balance text-3xl font-bold tracking-tight text-fg sm:text-4xl lg:text-5xl">
          {clients.length}+ brands partner with LeadGenLab
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-fg-muted">
          From enterprises and global corporations to beauty & healthcare, AI · IT · B2B, and clinics &
          professional services — brands across industries began AI Visibility Optimization with LeadGenLab.
        </p>
      </Container>
    </section>

    <section class="py-16 sm:py-20">
      <Container>
        <ul class="grid grid-cols-2 items-center gap-4 sm:grid-cols-3 lg:grid-cols-5">
          {
            clients.map((c) => (
              <li class="spotlight flex items-center justify-center rounded-2xl border border-border bg-surface p-6">
                <img
                  src={c.file}
                  alt={c.name}
                  loading="lazy"
                  decoding="async"
                  width="140"
                  height="70"
                  class="h-10 w-auto opacity-70 grayscale transition hover:opacity-100 hover:grayscale-0"
                />
              </li>
            ))
          }
        </ul>
      </Container>
    </section>

    <CtaBand />
  </main>
  <Footer />
</Layout>
