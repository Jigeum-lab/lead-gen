---
/** 헤어라인 카드 — 라이트 미니멀: 그림자 최소, 얇은 보더, hover 시 살짝 리프트. */
interface Props {
  class?: string;
  hover?: boolean;
}
const { class: cls = "", hover = false } = Astro.props;
---

<div
  class:list={[
    "rounded-2xl border border-border bg-surface p-7",
    hover && "transition-shadow hover:shadow-card",
    cls,
  ]}
>
  <slot />
</div>
