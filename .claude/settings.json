{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm ci)",
      "Bash(npm run build)",
      "Bash(npm run build:*)",
      "Bash(npm run lint)",
      "Bash(npm run dev:*)",
      "Bash(npm run test)",
      "Bash(npm run test:e2e)",
      "Bash(npm run start:dev)",
      "Bash(turbo:*)",
      "Bash(nest:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": ["Read(./**/.env)", "Read(./**/.env.*)", "Read(./**/*.pem)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(cat | python3 -c \"import sys,json;print(json.load(sys.stdin).get('tool_input',{}).get('file_path',''))\" 2>/dev/null); case \"$f\" in *.ts|*.tsx) cd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null && npx --no-install eslint --fix \"$f\" >/dev/null 2>&1 || true;; esac"
          }
        ]
      }
    ]
  }
}
