---
import Container from "../Container.astro";
import SectionHeading from "../SectionHeading.astro";
import { useT } from "../../../i18n/utils";
const t = useT(Astro.currentLocale).framework;
const framework = t.steps;
---

<section id="framework" class="border-y border-border bg-muted/40 py-24 sm:py-32">
  <Container>
    <SectionHeading align="center" eyebrow={t.eyebrow} title={t.title} lead={t.lead} class="mx-auto" />
    <ol class="mx-auto mt-14 grid max-w-5xl gap-px overflow-hidden rounded-2xl border border-border bg-border sm:grid-cols-2 lg:grid-cols-3">
      {
        framework.map(([n, t, d]) => (
          <li class="spotlight bg-surface p-7">
            <span class="font-mono text-2xl font-bold text-primary/30">{n}</span>
            <h3 class="mt-3 text-base font-semibold tracking-tight text-fg">{t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-fg-muted">{d}</p>
          </li>
        ))
      }
    </ol>
  </Container>
</section>
