---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  /** OG/Twitter 카드 이미지 (public 기준 절대경로). 기본 /og.png */
  image?: string;
  /** 검색 색인 제외 (내부 페이지) */
  noindex?: boolean;
}

const {
  title = "LeadGenLab — AI Visibility Optimization",
  description = "AI가 소비자의 판단을 대신하는 시대, 브랜드를 AI 응답에 노출시키는 AVO(AI Visibility Optimization) 전문 컨설팅.",
  image = "/og.png",
  noindex = false,
} = Astro.props;

// canonical·OG 절대 URL (astro.config의 site 기준)
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const siteName = "LeadGenLab";
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Pretendard (한국어 본문 폰트, --font-sans 토큰) -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- SPA식 부드러운 페이지 전환 (각 페이지는 정적 SSG 유지 → SEO 안전) -->
    <ClientRouter />

    <!-- 페이지별 head 주입 (JSON-LD 등) -->
    <slot name="head" />
  </head>
  <body>
    <!-- 페이지 전환 로딩바 (View Transitions와 함께, 전환 동안만 표시) -->
    <div id="nav-progress" transition:persist aria-hidden="true"></div>
    <slot />
    <script is:inline>
      // 전역 1회만 바인딩(View Transition 재실행 시 가드). document/window는 전환에도 유지됨.
      if (!window.__lglInit) {
        window.__lglInit = true;

        // 스포트라이트 카드 — .spotlight에 위임된 단일 pointermove 핸들러(경량·바닐라)
        addEventListener(
          "pointermove",
          (e) => {
            const el = e.target && e.target.closest && e.target.closest(".spotlight");
            if (!el) return;
            const r = el.getBoundingClientRect();
            el.style.setProperty("--mx", e.clientX - r.left + "px");
            el.style.setProperty("--my", e.clientY - r.top + "px");
          },
          { passive: true },
        );

        // 페이지 전환 로딩바 애니메이션
        const bar = () => document.getElementById("nav-progress");
        document.addEventListener("astro:before-preparation", () => {
          const b = bar();
          if (!b) return;
          b.style.transition = "none";
          b.style.opacity = "1";
          b.style.width = "0";
          requestAnimationFrame(() => {
            b.style.transition = "width 0.5s ease";
            b.style.width = "80%";
          });
        });
        document.addEventListener("astro:after-swap", () => {
          const b = bar();
          if (!b) return;
          b.style.width = "100%";
          setTimeout(() => {
            b.style.opacity = "0";
            b.style.width = "0";
          }, 250);
        });
      }
    </script>
  </body>
</html>
