---
import Container from "../Container.astro";
import clients from "../../../data/clients.json";
---

<section class="border-y border-border bg-muted/40">
  <Container class="py-12">
    <p class="text-center text-sm font-medium text-fg-subtle">
      SK · 하나 · KB 등 32개+ 브랜드와 함께합니다
    </p>
    <ul class="mt-8 grid grid-cols-3 items-center gap-x-8 gap-y-6 sm:grid-cols-4 lg:grid-cols-6">
      {
        clients.map((c) => (
          <li class="flex items-center justify-center">
            <img
              src={c.file}
              alt={c.name}
              loading="lazy"
              decoding="async"
              width="120"
              height="60"
              class="h-8 w-auto opacity-60 grayscale transition hover:opacity-100 hover:grayscale-0"
            />
          </li>
        ))
      }
    </ul>
  </Container>
</section>
