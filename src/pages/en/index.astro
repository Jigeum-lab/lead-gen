  <Navbar overHero />
  <main id="main-content" tabindex="-1">
    <Hero />
    <TrustStats />
    <LogoCloud />
    <Problems />
    <Framework />
    <Metrics />
    <Faq />
    <CtaBand />
  </main>
  <Footer />
