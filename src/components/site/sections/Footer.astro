---
import Container from "../Container.astro";
import { useT, getLang, localizePath } from "../../../i18n/utils";
const lang = getLang(Astro.currentLocale);
const t = useT(Astro.currentLocale).footer;
---

<footer class="border-t border-border bg-muted/40 py-16">
  <Container>
    <div class="grid gap-10 lg:grid-cols-[1.4fr_2fr]">
      <div class="space-y-3">
        <img src="/leadgenlab-wordmark.png" alt="LeadGenLab" width="1024" height="323" class="h-8 w-auto" />
        <p class="text-sm text-fg-muted">{t.tagline}</p>
        <p class="max-w-xs text-xs leading-relaxed text-fg-subtle">{t.desc}</p>
      </div>
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-3">
        {
          t.cols.map((col) => (
            <div>
              <p class="text-sm font-semibold text-fg">{col.title}</p>
              <ul class="mt-3 space-y-2">
                {col.links.map(([label, href]) => (
                  <li>
                    <a href={localizePath(href, lang)} class="text-sm text-fg-muted transition-colors hover:text-primary">
                      {label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
    <div class="mt-12 border-t border-border pt-6 text-xs leading-relaxed text-fg-subtle">
      <p>{t.addr1}</p>
      <p>{t.addr2}</p>
      <p class="mt-2">© {new Date().getFullYear()} LeadGenLab. All rights reserved.</p>
    </div>
  </Container>
</footer>
