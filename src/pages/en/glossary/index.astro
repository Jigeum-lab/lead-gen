---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import JsonLd from "../../../components/seo/JsonLd.astro";
import Navbar from "../../../components/site/sections/Navbar.astro";
import Footer from "../../../components/site/sections/Footer.astro";
import CtaBand from "../../../components/site/sections/CtaBand.astro";
import Container from "../../../components/site/Container.astro";
import Badge from "../../../components/site/Badge.astro";

const entries = (await getCollection("glossary"))
  .filter((e) => e.id.startsWith("en/"))
  .sort((a, b) => a.data.term.localeCompare(b.data.term, "en"));
const slugOf = (e) => e.id.replace(/^en\//, "");
const site = Astro.site?.href.replace(/\/$/, "") ?? "https://lead-gen.team";

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/en/` },
    { "@type": "ListItem", position: 2, name: "AI Search Glossary", item: `${site}/en/glossary/` },
  ],
};
const termSet = {
  "@type": "DefinedTermSet",
  "@id": `${site}/en/glossary/#termset`,
  name: "AI Search Glossary (GEO·AEO·SEO)",
  hasDefinedTerm: entries.map((e) => ({
    "@type": "DefinedTerm",
    name: e.data.term,
    description: e.data.definition,
    url: `${site}/en/glossary/${slugOf(e)}/`,
  })),
};
---

<Layout
  title="AI Search Glossary — core GEO·AEO·SEO terms | LeadGenLab"
  description="The 20 essential terms of GEO, AEO, SEO, and AI search optimization — generative search, entities, schema, E-E-A-T, and more, clearly defined for the AI Commerce era."
>
  <JsonLd slot="head" extra={[breadcrumb, termSet]} />
  <Navbar />
  <main id="main-content" tabindex="-1">
    <section class="border-b border-border bg-muted/40">
      <Container class="py-20 text-center sm:py-24">
        <Badge>AI Search Glossary</Badge>
        <h1 class="mt-5 text-balance text-4xl font-bold tracking-tight text-fg sm:text-5xl">
          AI Search Glossary
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-fg-muted">
          The {entries.length} essential terms of GEO, AEO, SEO, and AI search optimization — clearly
          defined to help you build the structure AI uses to understand and recommend your brand.
        </p>
      </Container>
    </section>

    <section class="py-16 sm:py-20">
      <Container>
        <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            entries.map((e) => (
              <li>
                <a
                  href={`/en/glossary/${slugOf(e)}/`}
                  class="spotlight flex h-full flex-col rounded-2xl border border-border bg-surface p-6 transition hover:border-border-strong hover:shadow-card"
                >
                  <span class="inline-flex w-fit rounded-full bg-primary-subtle px-2.5 py-0.5 text-xs font-semibold text-primary">
                    {e.data.term}
                  </span>
                  <h2 class="mt-3 text-base font-semibold leading-snug tracking-tight text-fg">
                    {e.data.title}
                  </h2>
                  <p class="mt-2 line-clamp-3 flex-1 text-sm leading-relaxed text-fg-muted">
                    {e.data.definition}
                  </p>
                  <span class="mt-4 text-sm font-medium text-primary">Read more →</span>
                </a>
              </li>
            ))
          }
        </ul>
      </Container>
    </section>

    <CtaBand />
  </main>
  <Footer />
</Layout>
