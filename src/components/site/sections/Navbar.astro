---
import Button from "../Button.astro";
import { KAKAO } from "../../../lib/links";
---

<header id="site-nav" class="sticky top-0 z-40">
  <div class="nav-shell">
    <div class="nav-inner mx-auto flex h-full max-w-6xl items-center justify-between gap-4 px-5 sm:px-6">
      <a href="/" class="flex items-center gap-2.5">
        <span
          class="flex size-8 items-center justify-center rounded-lg bg-primary text-on-primary text-sm font-bold"
          >L</span
        >
        <span class="text-base font-semibold tracking-tight">LeadGenLab</span>
      </a>
      <nav class="hidden items-center gap-7 text-sm text-fg-muted md:flex">
        <a href="/solutions/" class="transition-colors hover:text-fg">솔루션</a>
        <a href="/ai-visibility-optimization/" class="transition-colors hover:text-fg">AVO</a>
        <a href="/pricing/" class="transition-colors hover:text-fg">가격</a>
        <a href="/glossary/" class="transition-colors hover:text-fg">용어집</a>
        <a href="/about/" class="transition-colors hover:text-fg">회사소개</a>
      </nav>
      <Button href={KAKAO} size="md" class="hidden sm:inline-flex">무료 진단 요청</Button>
    </div>
  </div>
</header>

<style>
  /* 스크롤 시 전체폭 바 → 가운데 떠다니는 글래스 알약(pill)으로 모핑 (reactbits 스타일) */
  .nav-shell {
    width: 100%;
    /* 유한 max-width라야 52rem로 '보간'되어 부드럽게 좁아짐(none이면 스냅) */
    max-width: 120rem;
    height: 4rem;
    margin-inline: auto;
    margin-top: 0;
    border-style: solid;
    border-color: var(--border);
    border-width: 0 0 1px;
    border-radius: 0;
    background-color: color-mix(in oklab, var(--color-page) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition:
      width 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      max-width 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      height 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      margin-top 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      border-radius 0.55s ease,
      border-width 0.55s ease,
      box-shadow 0.55s ease,
      background-color 0.55s ease;
  }
  #site-nav.is-scrolled .nav-shell {
    width: calc(100% - 2.5rem);
    max-width: 52rem;
    height: 3.25rem;
    margin-top: 0.9rem;
    border-width: 1px;
    border-radius: 9999px;
    box-shadow: var(--shadow-lift);
    background-color: color-mix(in oklab, var(--color-page) 70%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-shell {
      transition: none;
    }
  }
</style>

<script>
  const sync = () => {
    const n = document.getElementById("site-nav");
    n?.classList.toggle("is-scrolled", window.scrollY > 24);
  };
  sync();
  addEventListener("scroll", sync, { passive: true });
  // View Transitions 후에도 동작 보장
  document.addEventListener("astro:page-load", sync);
</script>
