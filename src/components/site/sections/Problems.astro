---
import Container from "../Container.astro";
import Card from "../Card.astro";
import SectionHeading from "../SectionHeading.astro";
import { useT } from "../../../i18n/utils";
const t = useT(Astro.currentLocale).problems;
const problems = t.items;
---

<section id="solution" class="py-24 sm:py-32">
  <Container>
    <SectionHeading eyebrow={t.eyebrow} title={t.title} lead={t.lead} />
    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        problems.map((p, i) => (
          <Card hover>
            <span class="flex size-10 items-center justify-center rounded-lg bg-primary-subtle font-mono text-sm font-bold text-primary">
              {`0${i + 1}`}
            </span>
            <h3 class="mt-5 text-lg font-semibold tracking-tight text-fg">{p.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-fg-muted">{p.d}</p>
          </Card>
        ))
      }
    </div>
  </Container>
</section>
