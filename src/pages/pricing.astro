---
import Layout from "../layouts/Layout.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import Navbar from "../components/site/sections/Navbar.astro";
import Footer from "../components/site/sections/Footer.astro";
import CtaBand from "../components/site/sections/CtaBand.astro";
import Container from "../components/site/Container.astro";
import Badge from "../components/site/Badge.astro";
import Button from "../components/site/Button.astro";
import { KAKAO } from "../lib/links";

const tiers = [
  {
    n: "01",
    label: "Infrastructure",
    title: "AI가 브랜드를 학습할 기반 구축",
    price: "₩3,000,000~",
    unit: "초기 구축 (월 재청구 없음)",
    points: ["AI 가시성 현황 진단", "웹사이트 IA 재설계", "브랜드 엔티티 구조 설계", "Technical GEO/SEO 진단", "스키마 마크업·내부링크", "AI 학습 허브(워드프레스, 필요 시)"],
  },
  {
    n: "02",
    label: "Content Architecture",
    title: "AI가 인용·추천하는 콘텐츠 제작",
    price: "월 ₩5,000,000~",
    unit: "3개월 이상 누적 권장",
    featured: true,
    points: ["쿼리 클러스터 분석", "월 8~12건 (총 30~50건 시딩)", "임직원 심층 인터뷰 기반", "SCI급·최상위 출처 리서치", "meta·H·JSON-LD 포함 전달", "인포그래픽·썸네일 디자인"],
  },
  {
    n: "03",
    label: "Authority Seeding",
    title: "외부 신뢰 채널 UGC 시딩",
    price: "건당 ₩500,000~",
    unit: "채널·국가 범위에 따라 상이",
    points: ["위키 문서 설계·배포", "언론·PR 보도자료", "버티컬 플랫폼 리뷰 시딩", "UGC 전략·콘텐츠 시딩"],
  },
  {
    n: "04",
    label: "Conversion Alignment",
    title: "추천 이후 전환 설계",
    price: "별도 협의",
    unit: "퍼널 최적화 범위에 따라",
    points: ["랜딩 구조 개선", "비교 이후 CTA 재설계", "유입 후 구매 동선 최적화", "의사결정 기준 명확화"],
  },
  {
    n: "05",
    label: "Measurement",
    title: "AI 점유율 측정·개선",
    price: "월 ₩500,000~",
    unit: "지속 운영",
    points: ["브랜드 언급률 모니터링", "비교 포함률 분석", "경쟁사 대비 SOV 측정", "월간 리포트·개선 전략"],
  },
];

const site = Astro.site?.href.replace(/\/$/, "") ?? "https://lead-gen.team";
const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "홈", item: `${site}/` },
    { "@type": "ListItem", position: 2, name: "가격", item: `${site}/pricing/` },
  ],
};
---

<Layout
  title="가격 안내 — AVO 실행 영역별 | LeadGenLab"
  description="AVO Framework 실행 영역별 안내: Infrastructure ₩3,000,000~, 콘텐츠 월 ₩5,000,000~, Authority Seeding 건당 ₩500,000~, 측정 월 ₩500,000~. 자세한 견적은 무료 진단으로."
>
  <JsonLd slot="head" extra={[breadcrumb]} />
  <Navbar />
  <main id="main-content" tabindex="-1">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-border">
      <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-full bg-gradient-to-b from-primary-subtle/60 to-transparent"></div>
      <Container width="narrow" class="py-20 text-center sm:py-24">
        <Badge>Pricing</Badge>
        <h1 class="mt-5 text-balance text-3xl font-bold tracking-tight text-fg sm:text-4xl lg:text-5xl">
          AI 답변 내 브랜드 점유율, 지금 선점하세요
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-fg-muted">
          AVO Framework 기반 현황 진단 → 전략 → 실행 → 측정 → 개선. 아래는 실행 영역별 대략적인
          수행 금액이며, 자세한 견적은 기업 상황에 따라 달라지니 편하게 문의주세요.
        </p>
        <div class="mt-8">
          <Button href={KAKAO} size="lg">AI 가시성 무료 진단 요청</Button>
        </div>
      </Container>
    </section>

    <!-- 가격 카드 -->
    <section class="py-16 sm:py-20">
      <Container>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            tiers.map((t) => (
              <div
                class:list={[
                  "spotlight flex flex-col rounded-3xl border bg-surface p-7",
                  t.featured ? "border-primary ring-1 ring-primary/30" : "border-border",
                ]}
              >
                <div class="flex items-center justify-between">
                  <span class="text-sm font-semibold tracking-wide text-fg-subtle uppercase">{t.label}</span>
                  <span class="font-mono text-xs text-primary">{t.n}</span>
                </div>
                <h2 class="mt-3 text-lg font-bold tracking-tight text-fg">{t.title}</h2>
                <div class="mt-4">
                  <span class="text-2xl font-bold tracking-tight text-primary">{t.price}</span>
                  <p class="mt-1 text-xs text-fg-subtle">{t.unit}</p>
                </div>
                <ul class="mt-5 flex-1 space-y-2.5 border-t border-border pt-5">
                  {t.points.map((p) => (
                    <li class="flex gap-2 text-sm leading-relaxed text-fg-muted">
                      <svg class="mt-0.5 size-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                      {p}
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }

          <!-- 엔터프라이즈 통합 운영 -->
          <div class="flex flex-col justify-center rounded-3xl bg-ink p-8 text-on-dark">
            <span class="text-sm font-semibold tracking-wide text-on-dark-muted uppercase">Enterprise</span>
            <h2 class="mt-3 text-lg font-bold tracking-tight">통합 운영 (인프라+콘텐츠+신뢰+측정)</h2>
            <p class="mt-4 text-2xl font-bold tracking-tight">월 ₩5,000,000 ~ 20,000,000</p>
            <p class="mt-1 text-xs text-on-dark-muted">3개월 기준 평균 1,500만 ~ 6,000만원</p>
            <p class="mt-5 border-t border-white/15 pt-5 text-sm leading-relaxed text-on-dark-muted">
              전략 설계자·테크니컬 SEO 엔지니어·리서처·인터뷰 에디터·디자이너·데이터 분석가가 동시에 투입됩니다.
            </p>
            <div class="mt-6">
              <Button href={KAKAO} variant="ghost" class="text-on-dark hover:bg-white/10">전략 상담 신청</Button>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- 지금이 중요한 이유 -->
    <section class="border-t border-border bg-muted/40 py-20 text-center sm:py-24">
      <Container width="narrow">
        <Badge variant="neutral">지금이 중요한 이유</Badge>
        <h2 class="mt-4 text-balance text-2xl font-bold tracking-tight sm:text-3xl">
          AI는 먼저 학습한 브랜드를 선택합니다
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-fg-muted">
          AI는 학습 누적 구조입니다. 1년 먼저 시작한 브랜드는 추천 점유율을 먼저 확보합니다.
          2년 뒤 시작하면 경쟁사를 밀어내기 위한 비용이 훨씬 커집니다.
        </p>
      </Container>
    </section>

    <CtaBand />
  </main>
  <Footer />
</Layout>
