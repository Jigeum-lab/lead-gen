---
import { getCollection, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import JsonLd from "../../../components/seo/JsonLd.astro";
import Navbar from "../../../components/site/sections/Navbar.astro";
import Footer from "../../../components/site/sections/Footer.astro";
import Container from "../../../components/site/Container.astro";
import Button from "../../../components/site/Button.astro";
import { KAKAO, FEATPAPER } from "../../../lib/links";

export async function getStaticPaths() {
  const entries = (await getCollection("glossary")).filter((e) => e.id.startsWith("en/"));
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/^en\//, "") },
    props: { entry, entries },
  }));
}

const { entry, entries } = Astro.props;
const { Content } = await render(entry);
const site = Astro.site?.href.replace(/\/$/, "") ?? "https://lead-gen.team";
const slugOf = (e) => e.id.replace(/^en\//, "");
const url = `${site}/en/glossary/${slugOf(entry)}/`;

const idx = entries.findIndex((e) => e.id === entry.id);
const related = [1, 2, 3].map((o) => entries[(idx + o) % entries.length]);

const breadcrumb = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${site}/en/` },
    { "@type": "ListItem", position: 2, name: "Glossary", item: `${site}/en/glossary/` },
    { "@type": "ListItem", position: 3, name: entry.data.term, item: url },
  ],
};
const definedTerm = {
  "@type": "DefinedTerm",
  "@id": `${url}#term`,
  name: entry.data.term,
  description: entry.data.definition,
  url,
  inDefinedTermSet: `${site}/en/glossary/#termset`,
};
---

<Layout
  title={`${entry.data.title} | LeadGenLab Glossary`}
  description={entry.data.definition.slice(0, 155)}
>
  <JsonLd slot="head" extra={[breadcrumb, definedTerm]} />
  <Navbar />
  <main id="main-content" tabindex="-1">
    <Container width="narrow" class="py-12 sm:py-16">
      <nav class="flex items-center gap-1.5 text-sm text-fg-muted" aria-label="breadcrumb">
        <a href="/en/" class="hover:text-fg">Home</a>
        <span class="text-fg-subtle">/</span>
        <a href="/en/glossary/" class="hover:text-fg">Glossary</a>
        <span class="text-fg-subtle">/</span>
        <span class="text-fg">{entry.data.term}</span>
      </nav>

      <header class="mt-6">
        <span class="inline-flex rounded-full bg-primary-subtle px-3 py-1 text-xs font-semibold text-primary">
          {entry.data.term}
        </span>
        <h1 class="mt-4 text-balance text-3xl font-bold tracking-tight text-fg sm:text-4xl">
          {entry.data.title}
        </h1>
        <p class="mt-5 rounded-2xl border border-border bg-muted/50 p-5 text-lg leading-relaxed text-fg">
          {entry.data.definition}
        </p>
      </header>

      <article
        class="prose prose-neutral mt-10 max-w-none prose-headings:scroll-mt-24 prose-headings:font-bold prose-headings:tracking-tight prose-h2:text-2xl prose-h2:mt-12 prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-strong:text-fg"
      >
        <Content />
      </article>

      <div class="mt-12 rounded-2xl bg-ink p-8 text-center">
        <h2 class="text-xl font-bold tracking-tight text-on-dark">
          Is your brand visible inside AI answers?
        </h2>
        <p class="mx-auto mt-2 max-w-md text-sm text-on-dark-muted">
          Check your current exposure with a free AI visibility diagnosis.
        </p>
        <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
          <Button href={KAKAO}>Free diagnosis</Button>
          <Button href={FEATPAPER} variant="ghost" class="text-on-dark hover:bg-white/10">
            View company profile
          </Button>
        </div>
      </div>

      <section class="mt-12">
        <h2 class="text-sm font-semibold tracking-wide text-fg-muted uppercase">Related terms</h2>
        <ul class="mt-4 grid gap-4 sm:grid-cols-3">
          {
            related.map((r) => (
              <li>
                <a
                  href={`/en/glossary/${slugOf(r)}/`}
                  class="flex h-full flex-col rounded-xl border border-border bg-surface p-4 transition hover:border-border-strong hover:shadow-card"
                >
                  <span class="text-sm font-semibold text-fg">{r.data.term}</span>
                  <span class="mt-1 line-clamp-2 text-xs leading-relaxed text-fg-muted">
                    {r.data.definition}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
        <a href="/en/glossary/" class="mt-6 inline-block text-sm font-medium text-primary">
          ← Back to glossary
        </a>
      </section>
    </Container>
  </main>
  <Footer />
</Layout>
