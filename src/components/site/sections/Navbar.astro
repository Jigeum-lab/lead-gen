---
import Button from "../Button.astro";
import { KAKAO } from "../../../lib/links";
import { useT, getLang, localizePath, switchLangUrl } from "../../../i18n/utils";

interface Props {
  /** 다크 히어로 위에 올라가는 페이지(홈) — 최상단에서 어두운 글래스 + 흰 콘텐츠 */
  overHero?: boolean;
}
const { overHero = false } = Astro.props;

const lang = getLang(Astro.currentLocale);
const tn = useT(Astro.currentLocale).nav;
const links = tn.links;
const homeHref = localizePath("/", lang);
const altLang = lang === "en" ? "ko" : "en";
const altUrl = switchLangUrl(Astro.url.pathname, altLang);
const altLabel = altLang === "en" ? "EN" : "KO";
---

<header id="site-nav" class:list={["sticky top-0 z-40", overHero && "over-hero"]}>
  <div class="nav-shell">
    <div class="nav-inner mx-auto flex h-full max-w-6xl items-center justify-between gap-4 px-5 sm:px-6">
      <a href={homeHref} class="flex items-center" aria-label={tn.home}>
        <img src="/leadgenlab-wordmark.png" alt="LeadGenLab" width="1024" height="323" class="nav-logo h-7 w-auto transition-[filter] duration-300 sm:h-8" />
      </a>
      <nav class="hidden items-center gap-7 text-sm text-fg-muted lg:flex">
        {links.map(([label, href]) => <a href={localizePath(href, lang)} class="transition-colors hover:text-fg">{label}</a>)}
      </nav>
      <div class="flex items-center gap-2">
        <a href={altUrl} class="nav-lang hidden rounded-md px-2 py-1 text-xs font-semibold text-fg-muted transition hover:text-fg lg:inline-flex" aria-label={`Switch to ${altLabel}`}>{altLabel}</a>
        <Button href={KAKAO} size="md" class="hidden sm:inline-flex">{tn.cta}</Button>
        <button
          id="nav-toggle"
          type="button"
          class="flex size-9 items-center justify-center rounded-lg text-fg transition hover:bg-muted lg:hidden"
          aria-label={tn.menuOpen}
          data-open-label={tn.menuOpen}
          data-close-label={tn.menuClose}
          aria-expanded="false"
          aria-controls="nav-mobile"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- 모바일·태블릿 메뉴 패널 -->
  <div id="nav-mobile" class="mx-auto hidden max-w-6xl px-5 lg:hidden">
    <div class="mt-2 rounded-2xl border border-border bg-page/95 p-3 shadow-lift backdrop-blur-md">
      <nav class="flex flex-col">
        {links.map(([label, href]) => (
          <a href={localizePath(href, lang)} class="rounded-lg px-3 py-2.5 text-sm font-medium text-fg transition hover:bg-muted" data-nav-link>{label}</a>
        ))}
        <a href={altUrl} class="rounded-lg px-3 py-2.5 text-sm font-medium text-fg-muted transition hover:bg-muted" data-nav-link>{altLabel === "EN" ? "English" : "한국어"}</a>
      </nav>
      <a href={KAKAO} class="mt-2 block rounded-md bg-primary px-4 py-3 text-center text-sm font-medium text-on-primary">{tn.cta}</a>
    </div>
  </div>
</header>

<style>
  /* 스크롤 시 전체폭 바 → 가운데 떠다니는 글래스 알약(pill)으로 모핑 (reactbits 스타일) */
  /* 상단 갭은 헤더 padding-top으로(margin 상쇄 방지 — 스크롤해도 갭 일정 유지) */
  #site-nav {
    padding-top: 0.85rem;
    transition: padding-top 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }
  #site-nav.is-scrolled {
    padding-top: 1rem;
  }

  /* reactbits 스타일: 항상 떠 있는(top gap) 투명 frosted-glass 알약. 스크롤 시 살짝 좁고 진하게. */
  .nav-shell {
    width: calc(100% - 2rem);
    max-width: 64rem;
    height: 3.75rem;
    margin-inline: auto;
    border-radius: 9999px;
    background-color: color-mix(in oklab, var(--color-page) 56%, transparent);
    box-shadow: 0 10px 34px -20px rgb(10 10 10 / 0.45);
    backdrop-filter: blur(16px) saturate(150%);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    transition:
      max-width 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      height 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.55s ease,
      background-color 0.55s ease;
  }
  #site-nav.is-scrolled .nav-shell {
    max-width: 52rem;
    height: 3.25rem;
    box-shadow: var(--shadow-lift);
    background-color: color-mix(in oklab, var(--color-page) 72%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-shell {
      transition: none;
    }
  }

  /* 다크 히어로 위(최상단, 스크롤 전): 어두운 글래스 + 흰 콘텐츠 */
  #site-nav.over-hero:not(.is-scrolled) .nav-shell {
    background-color: color-mix(in oklab, var(--color-ink) 26%, transparent);
  }
  #site-nav.over-hero:not(.is-scrolled) nav a {
    color: rgba(255, 255, 255, 0.82);
  }
  #site-nav.over-hero:not(.is-scrolled) nav a:hover {
    color: #fff;
  }
  #site-nav.over-hero:not(.is-scrolled) #nav-toggle {
    color: #fff;
  }
  #site-nav.over-hero:not(.is-scrolled) .nav-logo {
    filter: brightness(0) invert(1);
  }
</style>

<script is:inline>
  // 전역 1회 바인딩(View Transition 재실행 가드). 요소는 페이지마다 새로 생겨 dataset.bound로 재바인딩.
  if (!window.__navInit) {
    window.__navInit = true;
    var sync = function () {
      var n = document.getElementById("site-nav");
      if (n) n.classList.toggle("is-scrolled", window.scrollY > 24);
    };
    var initMenu = function () {
      var toggle = document.getElementById("nav-toggle");
      var panel = document.getElementById("nav-mobile");
      if (!toggle || !panel || toggle.dataset.bound) return;
      toggle.dataset.bound = "1";
      var setOpen = function (open) {
        panel.classList.toggle("hidden", !open);
        toggle.setAttribute("aria-expanded", String(open));
        toggle.setAttribute("aria-label", open ? toggle.dataset.closeLabel : toggle.dataset.openLabel);
      };
      toggle.addEventListener("click", function () {
        setOpen(panel.classList.contains("hidden"));
      });
      panel.querySelectorAll("[data-nav-link]").forEach(function (a) {
        a.addEventListener("click", function () {
          setOpen(false);
        });
      });
    };
    addEventListener("scroll", sync, { passive: true });
    document.addEventListener("astro:page-load", function () {
      sync();
      initMenu();
    });
    sync();
    initMenu();
  }
</script>
