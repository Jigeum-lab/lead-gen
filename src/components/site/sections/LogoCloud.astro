---
import Container from "../Container.astro";
import clients from "../../../data/clients.json";
import { useT } from "../../../i18n/utils";
const t = useT(Astro.currentLocale).logos;

const half = Math.ceil(clients.length / 2);
// 트랙당 콘텐츠를 2배로 깔아 와이드 화면에서도 빈틈 없이 끊김 없는 루프 보장
const row1 = [...clients.slice(0, half), ...clients.slice(0, half)];
const row2 = [...clients.slice(half), ...clients.slice(half)];
const rows = [
  { items: row1, reverse: false },
  { items: row2, reverse: true },
];
---

<section class="border-y border-border bg-muted/40 py-16">
  <Container>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <p class="text-center text-sm font-medium text-fg-subtle">{t.caption}</p>
      <!-- 자동 이동 콘텐츠 일시정지 (WCAG 2.2.2) -->
      <button
        id="marquee-toggle"
        type="button"
        aria-pressed="false"
        aria-label={t.pause}
        data-pause-label={t.pause}
        data-play-label={t.play}
        class="inline-flex size-7 items-center justify-center rounded-full border border-border bg-surface text-fg-muted transition hover:text-fg"
      >
        <svg data-icon="pause" class="size-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>
        <svg data-icon="play" class="hidden size-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
      </button>
    </div>
  </Container>

  <div id="logo-marquee" class="mt-10 space-y-8">
    {
      rows.map((row) => (
        <div class:list={["marquee", row.reverse && "marquee--reverse"]}>
          {[0, 1].map((dup) => (
            <ul class="marquee__track" aria-hidden={dup === 1 ? "true" : undefined}>
              {row.items.map((c) => (
                <li class="flex shrink-0 items-center">
                  <img
                    src={c.file}
                    alt={c.name}
                    loading="lazy"
                    decoding="async"
                    width="180"
                    height="90"
                    class="h-16 w-auto opacity-65 grayscale transition hover:opacity-100 hover:grayscale-0"
                  />
                </li>
              ))}
            </ul>
          ))}
        </div>
      ))
    }
  </div>
</section>

<script is:inline>
  (function () {
    function init() {
      var btn = document.getElementById("marquee-toggle");
      if (!btn || btn.dataset.bound) return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", function () {
        var marquees = document.querySelectorAll("#logo-marquee .marquee");
        if (!marquees.length) return;
        var willPause = !marquees[0].classList.contains("is-paused");
        marquees.forEach(function (m) {
          m.classList.toggle("is-paused", willPause);
        });
        btn.setAttribute("aria-pressed", String(willPause));
        btn.setAttribute("aria-label", willPause ? btn.dataset.playLabel : btn.dataset.pauseLabel);
        btn.querySelector('[data-icon="pause"]').classList.toggle("hidden", willPause);
        btn.querySelector('[data-icon="play"]').classList.toggle("hidden", !willPause);
      });
    }
    init();
    document.addEventListener("astro:page-load", init);
  })();
</script>
